{
  "schema_version": 2,
  "status": "reviewer-revised submission pipeline with precision-aware lability replacement",
  "policy": {
    "move_numbered_scripts": false,
    "reason": "The numbered ch1_global/v2 paths generated the frozen observation and coefficient artifacts and remain stable provenance targets.",
    "new_analysis_version_required_for": [
      "trait definition changes",
      "measurement threshold changes",
      "taxon acceptance changes",
      "environmental data changes",
      "tree scenario changes"
    ]
  },
  "stages": {
    "climate_coefficients": {
      "script": "ch1_global/v2/75_run_exhaustive_within_species_climate_analysis.py",
      "inputs": ["exhaustive spatially thinned primary observation table"],
      "outputs": [
        "strict_spatial_thinned_with_chelsa.csv",
        "exhaustive_within_species_climate_models.csv"
      ],
      "rerun_policy": "Only when the exhaustive spatial cohort, CHELSA source or extraction code changes."
    },
    "legacy_lability_withdrawn": {
      "script": "ch1_global/v2/77_build_lability_axes_and_supplement.py",
      "status": "retained for provenance; raw absolute-slope RMS and quadrants are not manuscript evidence",
      "reason": "The legacy environmental-responsiveness score was strongly confounded with species slope sample size and standard error."
    },
    "precision_aware_lability": {
      "script": "analysis/reanalyze_lability_precision.py",
      "workflow": ".github/workflows/ch1-reviewer-precision-reanalysis.yml",
      "frozen_input_artifact": 8330350031,
      "inputs": [
        "species_lability_axes.csv",
        "species_trait_within_variation.csv",
        "table_s2_species_specific_coefficients.csv"
      ],
      "outputs": [
        "legacy_precision_diagnostic_species.csv",
        "revised_species_axes.csv",
        "revised_trait_association_energy.csv",
        "revised_module_summary.csv",
        "hierarchical_variance_group_summary.csv",
        "reviewer_precision_summary.json",
        "figure_precision_audit.svg",
        "figure_revised_variation_association.svg"
      ]
    },
    "claims": {
      "script": "analysis/validate_final_claims.py",
      "inputs": ["manuscript/final_claims.json"],
      "outputs": ["validated reviewer-revised claim registry"]
    },
    "submission_validation": {
      "script": "ch1_global/v2/69_validate_submission_outputs.py",
      "config": "ch1_global/v2/submission_config.json"
    },
    "submission_manifest": {
      "script": "ch1_global/v2/70_build_submission_manifest.py",
      "config": "ch1_global/v2/submission_config.json",
      "outputs": ["checksums", "table dimensions", "software versions", "commit identity"]
    }
  },
  "revised_primary_parameters": {
    "minimum_observations_per_species_trait_predictor": 10,
    "linear_traits": 7,
    "predictors_per_trait": 4,
    "module_weighting": "equal orientation, colour and shape weights",
    "hue_in_precision_test": "excluded because archived joint species hue vectors lack component standard errors",
    "bootstrap_repeats": 5000,
    "bootstrap_seed": 20260722
  }
}
